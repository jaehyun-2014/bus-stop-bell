<?xml version="1.0" encoding="utf-8"?>
<!--
    위젯의 기본 속성을 정의합니다.
    - minWidth/minHeight: 위젯 최소 크기 (2x2 셀 기준)
    - updatePeriodMillis: 자동 업데이트 주기 (0 = 자동 업데이트 없음)
    - configure: 위젯 추가 시 실행할 설정 액티비티
    - widgetCategory: home_screen (홈 화면 위젯)
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="110dp"
    android:targetCellWidth="2"
    android:targetCellHeight="2"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/widget_sound_layout"
    android:configure="com.manus.soundboard_flutter.SoundWidgetConfigureActivity"
    android:widgetCategory="home_screen"
    android:resizeMode="horizontal|vertical"
    android:previewImage="@drawable/widget_preview" />
